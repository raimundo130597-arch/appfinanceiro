# ─────────────────────────────────────────────────────────────────────────────
# CONFIGURAÇÃO DO SUPABASE
# Copie este arquivo para .env.local e preencha com seus valores.
# NUNCA commite o .env.local — ele está no .gitignore.
# ─────────────────────────────────────────────────────────────────────────────

# URL do projeto Supabase
# Encontre em: Supabase Dashboard → Project Settings → API → Project URL
NEXT_PUBLIC_SUPABASE_URL=https://SEU_PROJECT_REF.supabase.co

# Chave anon/public do Supabase (segura para expor no frontend)
# A segurança real vem das políticas RLS configuradas no banco.
# Encontre em: Supabase Dashboard → Project Settings → API → anon public
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua_chave_anon_aqui

# ─────────────────────────────────────────────────────────────────────────────
# PARA DEPLOY NA VERCEL:
# Adicione essas mesmas variáveis em:
# Vercel Dashboard → Project → Settings → Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
